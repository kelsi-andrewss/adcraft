# Google AI Studio API key for Gemini models (generation + evaluation)
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic API key for Claude evaluation (cross-model tie-breaking)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# SQLite database path (default: data/ads.db)
DATABASE_PATH=data/ads.db

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
